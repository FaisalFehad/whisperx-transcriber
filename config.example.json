{
    "_comment": "Copy this file to config.json and change only what you need.",
    "_comment2": "Any value you omit will use the built-in default.",

    "default_model": "parakeet",
    "language": "en",

    "paths": {
        "obsidian_base": "~/Library/Mobile Documents/iCloud~md~obsidian/Documents/Interviews",
        "recordings_subdir": "Recordings",
        "scripts_subdir": "Scripts"
    },

    "recording": {
        "sample_rate": 16000,
        "silence_threshold": 0.005,
        "silence_timeout_minutes": 10,
        "mic_low_warning_seconds": 10,
        "virtual_device_names": ["Aggregate", "Multi-Output"]
    },

    "normalize": {
        "enabled": true,
        "target_rms": 0.05,
        "peak_headroom_db": 1.0
    },

    "denoise": {
        "_comment": "Off by default. Enable with --denoise flag for noisy recordings that start with silence.",
        "enabled": false,
        "factor": 2.0,
        "noise_profile_seconds": 3,
        "n_fft": 2048,
        "hop_length": 512
    },

    "parakeet": {
        "chunk_duration": 30.0
    },

    "whisper": {
        "hallucination_silence_threshold": 2.0
    },

    "diarization": {
        "enabled": true,
        "mlx_model": "mlx-community/diar_streaming_sortformer_4spk-v2.1-fp16",
        "mlx_chunk_duration": 10.0,
        "threshold": 0.5,
        "min_duration": 0.0,
        "merge_gap": 0.0
    },

    "live": {
        "model": "parakeet",
        "chunk_interval_seconds": 120,
        "min_chunk_interval": 60,
        "max_chunk_interval": 300,
        "chunk_overlap_seconds": 5,
        "min_chunk_seconds": 30,
        "struggle_ratio": 0.7,
        "rec_only_ratio": 1.5
    },

    "watch": {
        "silence_timeout_minutes": 10,
        "min_recording_minutes": 2,
        "model": "parakeet",
        "calendars": [],
        "end_buffer_minutes": 2,
        "refresh_hours": 3,
        "record_only": true
    },

    "audio": {
        "keep_recording": true,
        "diarize_mic": false
    },

    "auto_title_from_calendar": true,
    "audio_formats": [".wav", ".mp3", ".m4a", ".ogg", ".flac", ".webm"],

    "list": {
        "max_recordings": 20
    }
}
